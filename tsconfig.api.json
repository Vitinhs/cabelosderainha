{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "lib": [
            "ES2020"
        ],
        "jsx": "react-jsx",
        "outDir": ".vercel/output/functions",
        "noEmit": false,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true,
        "types": [
            "node",
            "@vercel/node"
        ]
    },
    "include": [
        "api/**/*.ts",
        "src/server/**/*.ts"
    ]
}